datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

enum GlobalRole {
  SUPER_ADMIN
  PLATFORM_OBSERVER
  SUPPORT_ENGINEER
}

enum TenantRole {
  PROPERTY_ADMIN
  MANAGER
  STAFF
  CUSTOMER
  DEPENDENT
}

enum BookingStatus {
  DRAFT
  PAYMENT_PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CLOSED
  CANCELLED_BY_GUEST
  CANCELLED_BY_PROPERTY
  NO_SHOW
}

model Tenant {
  id         String            @id @default(uuid())
  name       String
  slug       String            @unique
  status     String            @default("ACTIVE") // ACTIVE, SUSPENDED_FOR_NON_PAYMENT, TRIAL_PERIOD, SOFT_DELETED
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  properties Property[]
  userRoles  UserRoleTenant[]
}

model User {
  id          String            @id @default(uuid())
  phoneNumber String            @unique
  fullName    String
  email       String?           @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  globalRoles UserGlobalRole[]
  tenantRoles UserRoleTenant[]
  bookings    Booking[]
  auditLogs   PlatformAuditLog[]
}

model UserGlobalRole {
  id        String     @id @default(uuid())
  userId    String
  role      GlobalRole
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, role])
}

model UserRoleTenant {
  id        String     @id @default(uuid())
  userId    String
  tenantId  String
  role      TenantRole
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([userId, tenantId, role])
}

model Property {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms     Room[]
  @@index([tenantId])
}

model Room {
  id          String    @id @default(uuid())
  propertyId  String
  roomNumber  String
  isDormitory Boolean   @default(false)
  bunkCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings    Booking[]
  @@index([propertyId])
}

model Booking {
  id         String        @id @default(uuid())
  tenantId   String
  propertyId String
  roomId     String?
  guestId    String
  status     BookingStatus @default(DRAFT)
  checkInAt  DateTime
  checkOutAt DateTime
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  guest      User          @relation(fields: [guestId], references: [id])
  room       Room?         @relation(fields: [roomId], references: [id])
  @@index([tenantId])
  @@index([guestId])
}

model PlatformAuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  payload    Json
  ipAddress  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}
