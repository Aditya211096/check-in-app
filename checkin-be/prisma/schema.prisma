// Full Prisma schema for checkin-be
// Multi-tenant: tenantId on every tenant-scoped table + Postgres RLS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  PROPERTY_ADMIN
  MANAGER
  STAFF
  CUSTOMER
  DEPENDENT
}

enum BookingStatus {
  DRAFT
  PAYMENT_PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CLOSED
  CANCELLED_BY_GUEST
  CANCELLED_BY_PROPERTY
  NO_SHOW
  OVERSTAY
}

enum KycStatus {
  PENDING
  VERIFYING
  APPROVED
  REJECTED
  EXPIRED
}

enum RequestState {
  NEW
  ACKNOWLEDGED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CONFIRMED
  REOPENED
  ESCALATED
  AUTO_ESCALATED
}

enum RoomKind {
  DORM
  PRIVATE
}

enum BedStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  DIRTY
  OUT_OF_ORDER
}

enum FoodOrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  PREPARING
  DELIVERED
}

enum PaymentMethod {
  PAY_NOW
  COD
  ROOM_TAB
}

model Tenant {
  id            String     @id @default(uuid())
  name          String
  plan          String     @default("STARTER")
  featureFlags  Json       @default("{}")
  branding      Json       @default("{}")
  createdAt     DateTime   @default(now())
  properties    Property[]
  users         User[]
  auditLogs     AuditLog[]
}

model Property {
  id         String     @id @default(uuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  slug       String     @unique
  name       String
  city       String
  address    String
  gstin      String?
  policies   Json       @default("{}")
  checkInAt  String     @default("14:00")
  checkOutAt String     @default("11:00")
  roomTypes  RoomType[]
  bookings   Booking[]
  createdAt  DateTime   @default(now())
  @@index([tenantId])
}

model RoomType {
  id         String   @id @default(uuid())
  tenantId   String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  name       String
  kind       RoomKind
  basePrice  Int
  rooms      Room[]
  @@index([tenantId, propertyId])
}

model Room {
  id         String   @id @default(uuid())
  tenantId   String
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  code       String
  beds       Bed[]
  @@index([tenantId])
}

model Bed {
  id          String       @id @default(uuid())
  tenantId    String
  roomId      String
  room        Room         @relation(fields: [roomId], references: [id])
  code        String
  status      BedStatus    @default(AVAILABLE)
  assignments BookingBed[]
  @@index([tenantId])
}

// Historical rate records per room/roomType for Owner financial analysis over time
model RoomPriceHistory {
  id            String    @id @default(uuid())
  tenantId      String
  propertyId    String
  roomTypeId    String?
  bedId         String?
  pricePerNight Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  @@index([tenantId, propertyId, effectiveFrom])
}

model User {
  id              String           @id @default(uuid())
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  role            Role
  subRole         String?          // COOK | HOUSEKEEPING | MAINTENANCE | RECEPTION
  phone           String           @unique
  email           String?
  fullName        String?
  disabled        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  customerProfile CustomerProfile?
}

// GLOBAL — not tenant-scoped
model CustomerProfile {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  fullName     String
  dob          DateTime?
  address      String?
  emergency    String?
  consentShare Boolean       @default(true)
  dependents   Dependent[]
  kycDocuments KycDocument[]
  bookings     Booking[]
  createdAt    DateTime      @default(now())
}

model Dependent {
  id        String          @id @default(uuid())
  profileId String
  profile   CustomerProfile @relation(fields: [profileId], references: [id])
  fullName  String
  relation  String
  dob       DateTime?
}

// GLOBAL — encrypted files in GCS
model KycDocument {
  id        String          @id @default(uuid())
  profileId String
  profile   CustomerProfile @relation(fields: [profileId], references: [id])
  docType   String
  gcsObject String // sha256(userId+salt+name)
  fileHash  String
  status    KycStatus       @default(PENDING)
  expiresAt DateTime?
  meta      Json            @default("{}")
  consents  KycConsent[]
  createdAt DateTime        @default(now())
}

model KycConsent {
  id         String      @id @default(uuid())
  documentId String
  document   KycDocument @relation(fields: [documentId], references: [id])
  tenantId   String
  propertyId String
  purpose    String
  grantedAt  DateTime    @default(now())
  revokedAt  DateTime?
  @@index([tenantId, propertyId])
}

model Booking {
  id          String         @id @default(uuid())
  tenantId    String
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id])
  profileId   String
  profile     CustomerProfile @relation(fields: [profileId], references: [id])
  status      BookingStatus  @default(DRAFT)
  checkIn     DateTime
  checkOut    DateTime
  totalAmount Int            @default(0)
  currency    String         @default("INR")
  specialReqs Json           @default("{}")
  beds        BookingBed[]
  guests      BookingGuest[]
  requests    Request[]
  complaints  Complaint[]
  foodOrders  FoodOrder[]
  roomTab     RoomTab?
  payments    Payment[]
  feedback    Feedback?
  createdAt   DateTime       @default(now())
  @@index([tenantId, propertyId, status])
}

model BookingBed {
  id        String  @id @default(uuid())
  tenantId  String
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])
  bedId     String
  bed       Bed     @relation(fields: [bedId], references: [id])
  @@index([tenantId])
}

model BookingGuest {
  id          String  @id @default(uuid())
  tenantId    String
  bookingId   String
  booking     Booking @relation(fields: [bookingId], references: [id])
  fullName    String
  isPrimary   Boolean @default(false)
  dependentId String?
}

model MenuItem {
  id         String   @id @default(uuid())
  tenantId   String
  propertyId String
  name       String
  category   String
  price      Int
  available  Boolean  @default(true)
  image      String?
  createdAt  DateTime @default(now())
  @@index([tenantId, propertyId])
}

model FoodOrder {
  id                 String          @id @default(uuid())
  tenantId           String
  bookingId          String
  booking            Booking         @relation(fields: [bookingId], references: [id])
  items              Json
  totalAmount        Int
  status             FoodOrderStatus @default(PENDING)
  customInstructions String?
  rejectionReason    String?
  paymentMethod      PaymentMethod   @default(ROOM_TAB)
  paid               Boolean         @default(false)
  createdAt          DateTime        @default(now())
  @@index([tenantId, bookingId])
}

model RoomTab {
  id          String   @id @default(uuid())
  tenantId    String
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  totalLedger Int      @default(0)
  status      String   @default("OPEN") // OPEN | SETTLED
  createdAt   DateTime @default(now())
}

model Request {
  id               String       @id @default(uuid())
  tenantId         String
  bookingId        String
  booking          Booking      @relation(fields: [bookingId], references: [id])
  category         String
  priority         String       @default("NORMAL")
  state            RequestState @default(NEW)
  etaMinutes       Int?
  voiceNoteUri     String?
  resolutionRemark String?
  assignedToId     String?
  assignedAt       DateTime?
  ackAt            DateTime?
  resolvedAt       DateTime?
  events           ServiceEvent[]
  createdAt        DateTime     @default(now())
  @@index([tenantId, state])
}

model Complaint {
  id           String       @id @default(uuid())
  tenantId     String
  bookingId    String
  booking      Booking      @relation(fields: [bookingId], references: [id])
  category     String
  severity     String       @default("NORMAL")
  state        RequestState @default(NEW)
  etaMinutes   Int?
  assignedToId String?
  createdAt    DateTime     @default(now())
}

model ServiceEvent {
  id        String   @id @default(uuid())
  tenantId  String
  requestId String?
  request   Request? @relation(fields: [requestId], references: [id])
  actorId   String
  fromState String?
  toState   String
  note      String?
  photoUri  String?
  createdAt DateTime @default(now())
  @@index([tenantId])
}

model Feedback {
  id             String   @id @default(uuid())
  tenantId       String
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id])
  rating         Int
  comment        String?
  anonymousShare Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Payment {
  id         String   @id @default(uuid())
  tenantId   String
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  provider   String
  providerId String
  amount     Int
  currency   String   @default("INR")
  status     String
  createdAt  DateTime @default(now())
}

model Notification {
  id          String    @id @default(uuid())
  tenantId    String?
  userId      String
  event       String
  channel     String    // push | sms | email | in_app | whatsapp
  payload     Json
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  @@index([userId, createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  actorId   String?
  action    String
  entity    String
  entityId  String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())
  @@index([tenantId, createdAt])
}
